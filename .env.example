APP_VERSION=1.0.0
LOG_LEVEL=INFO

# ---- public entry point -----------------------------------------------------
PUBLIC_PORT=8080

# ---- database ---------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_USER=review360
DB_PASS=review360
DB_NAME=review360

# ---- services ---------------------------------------------------------------
GATEWAY_NAME=Review 360 Gateway
GATEWAY_PORT=8010
DATA_SERVICE_NAME=Review 360 Data Service
DATA_SERVICE_PORT=8011
DATA_SERVICE_URL=http://data-service:8011

# Shared secret: gateway -> data-service
SERVICE_TOKEN=change-me-service-token
# Shared secret: bot -> gateway
BOT_API_TOKEN=change-me-bot-token

# ---- auth -------------------------------------------------------------------
JWT_SECRET=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_TTL_HOURS=24
AUTH_COOKIE_NAME=review360_token
# Telegram Login Widget needs a real domain registered with BotFather and does
# not work on localhost — keep dev login on locally, turn it OFF in production.
DEV_LOGIN_ENABLED=true

# ---- telegram ---------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
GATEWAY_URL=http://gateway:8010

# ---- review rules -----------------------------------------------------------
SCORE_MIN=1
SCORE_MAX=5
# Peer averages stay hidden until this many answers exist (anonymity guard)
MIN_RESPONSES_FOR_RESULTS=3

CORS_ORIGINS=http://localhost:8080
